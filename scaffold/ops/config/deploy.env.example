# Shared deploy — copy to deploy.env (gitignored)
# Service/container names: set COMPOSE_* below OR let compose-gen derive from repo folder name (<slug>-api, <slug>-app, …)

DEPLOY_SERVER=user@YOUR_SERVER
DEPLOY_PROJECT=YOUR_PROJECT_SLUG

# Docker / compose identity (optional — compose-gen defaults from DEPLOY_PROJECT or repo folder)
# COMPOSE_PROJECT_NAME=your-app
# COMPOSE_API_SERVICE=your-app-api
# COMPOSE_APP_SERVICE=your-app-app
# COMPOSE_WORKER_SERVICE=your-app-worker
# DOCKER_NETWORK=your-app-net

# Optional project-local SSH — see secrets/ssh/README.md
# DEPLOY_SSH_IDENTITY_FILE=secrets/ssh/id_ed25519
# DEPLOY_SSH_CONFIG_FILE=secrets/ssh/config
# DEPLOY_SSH_OPTIONS=-o StrictHostKeyChecking=accept-new

# DEPLOY_SERVER_BASE=/home/user
