{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "geostat.ops project manifest",
  "type": "object",
  "required": ["version", "package", "secrets", "compose", "modules"],
  "properties": {
    "version": { "type": "integer", "minimum": 2 },
    "package": {
      "type": "string",
      "description": "Relative path from project root to geostat-kit package"
    },
    "secrets": { "type": "string" },
    "compose": {
      "type": "object",
      "required": ["catalog"],
      "properties": {
        "catalog": { "type": "string" },
        "syncModules": { "type": "string" }
      }
    },
    "stack": {
      "type": "object",
      "properties": {
        "composeDir": { "type": "string" }
      }
    },
    "cli": {
      "type": "object",
      "properties": {
        "aliases": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Shortcut → modules.<id> (e.g. fe → frontend, be → backend)"
        }
      }
    },
    "stackDeploy": {
      "type": "object",
      "properties": {
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["module", "command"],
            "properties": {
              "module": { "type": "string" },
              "command": { "type": "string" },
              "args": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Placeholders: {environment} dev|prod, {env} same"
              }
            }
          }
        }
      }
    },
    "modules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "path", "secretsModule", "role"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Driver id from drivers/registry.json (e.g. java-boot, node-vite)"
          },
          "role": {
            "type": "string",
            "enum": ["ui", "api", "worker", "gateway", "data", "other"],
            "description": "Logical role for stack order, layout, and default CLI shortcuts"
          },
          "path": { "type": "string" },
          "secretsModule": { "type": "string" },
          "credentials": {
            "type": "array",
            "description": "Credential files under secretsModule (overrides global adapters.gcp for this module)",
            "items": {
              "type": "object",
              "required": ["file"],
              "properties": {
                "file": { "type": "string" },
                "mount": { "type": "string" },
                "envVar": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "scripts": {
            "type": "string",
            "description": "Deprecated — use package drivers; optional wrapper path only"
          },
          "target": { "type": "string" },
          "debug": {
            "type": "object",
            "description": "VS Code Run and Debug (optional; java-boot auto-detects *Application.java)",
            "properties": {
              "label": { "type": "string" },
              "npmScript": { "type": "string" },
              "envFile": { "type": "string" },
              "mainClass": { "type": "string" },
              "projectName": { "type": "string" },
              "java": {
                "type": "object",
                "properties": {
                  "mainClass": { "type": "string" },
                  "projectName": { "type": "string" }
                }
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    "vscode": {
      "type": "object",
      "properties": {
        "folder": { "type": "string" },
        "geostatScript": { "type": "string" }
      },
      "additionalProperties": false
    },
    "features": {
      "type": "object",
      "description": "Optional project capabilities (package reads; defaults off in scaffold)",
      "additionalProperties": { "type": "boolean" }
    },
    "adapters": {
      "type": "object",
      "properties": {
        "gcp": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "credentialsFile": { "type": "string" },
            "containerMount": { "type": "string" },
            "envVar": { "type": "string" }
          },
          "additionalProperties": false
        },
        "nginx": {
          "type": "object",
          "properties": {
            "template": { "type": "string" },
            "output": { "type": "string" },
            "envExample": { "type": "string" },
            "env": { "type": "string" }
          },
          "additionalProperties": true
        },
        "embed": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "ci": {
      "type": "object",
      "properties": {
        "integration": { "type": "string" },
        "prepareEnv": { "type": "string" },
        "waitHealth": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
